# New Relic credentials
NEW_RELIC_ACCOUNT_ID=your_account_id
NEW_RELIC_INSERT_KEY=your_insert_key

# MQTT broker connection for relay service
MQTT_BROKER_URL=mqtt://mosquitto:1883
MQTT_USERNAME=nr-relay
MQTT_PASSWORD=change-me-relay

# Comma-separated list of MQTT topics to subscribe to (default: # = all topics)
# Examples: MQTT_TOPICS=#  or  MQTT_TOPICS=sensors/#,devices/#
MQTT_TOPICS=#

# Relay tuning
BATCH_SIZE=500
BATCH_INTERVAL_MS=2000
LOG_LEVEL=info
